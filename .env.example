# web-db-user (Manus 部署) 环境变量模板
# 注意：不要把真实密钥提交到 Git。

# 必填：数据库与会话
DATABASE_URL=mysql://user:password@host:3306/web_db_user
COOKIE_SECRET=replace_with_random_secret
VITE_APP_ID=web-db-user
VITE_APP_TITLE=web-db-user 融合量化平台

# 可选：免费数据源（推荐）
TIINGO_API_KEY=replace_me
ALPHAVANTAGE_API_KEY=replace_me
ALPACA_API_KEY=replace_me
ALPACA_SECRET_KEY=replace_me
FINNHUB_API_KEY=replace_me

# 可选：AI（仅免费 Gemini；OpenAI 留空）
GEMINI_API_KEY=replace_me
OPENAI_API_KEY=

# Manus 平台内置（通常由运行环境注入）
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
